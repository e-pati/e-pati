NODE_ENV=production
PORT=3000

# Required
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
REDIS_URL="rediss://USER:PASSWORD@HOST:6379"
CORS_ORIGINS="https://portal.example.gov.tr,https://vetcep.com"

# Required secrets. Generate each with at least 32 random bytes.
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
QR_TOKEN_SECRET=""
QR_TOKEN_TTL="24h"

# Email / OTP
RESEND_API_KEY=""
MAIL_FROM="VetCep <no-reply@example.gov.tr>"
OTP_EMAIL_TO=""

# Firebase push notifications
FIREBASE_SERVICE_ACCOUNT_JSON=""
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
NOTIFICATION_WORKER_ENABLED="true"

# Meta WhatsApp Cloud API
META_WHATSAPP_API_VERSION="v20.0"
META_WHATSAPP_TOKEN=""
META_WHATSAPP_PHONE_NUMBER_ID=""
META_WHATSAPP_BUSINESS_ACCOUNT_ID=""
META_WHATSAPP_VERIFY_TOKEN=""
META_WHATSAPP_APP_SECRET=""
META_WHATSAPP_LANGUAGE="tr"
META_WHATSAPP_TEMPLATE_EXAM_SUMMARY="exam_summary"
META_WHATSAPP_TEMPLATE_VACCINE_REMINDER="vaccine_reminder"
META_WHATSAPP_TEMPLATE_APPOINTMENT_REMINDER="appointment_reminder"
META_WHATSAPP_TEMPLATE_LAB_RESULT_READY="lab_result_ready"

# Cloudflare R2, S3-compatible storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
R2_SIGNED_URL_TTL_SECONDS="900"
