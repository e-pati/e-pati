NODE_ENV=development
PORT=3000

# PostgreSQL connection string from Supabase, Railway, or local Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/e_pati?schema=public"

# Comma-separated origins allowed by CORS.
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# JWT secrets must be long random values in real environments.
JWT_ACCESS_SECRET="replace-with-access-token-secret"
JWT_REFRESH_SECRET="replace-with-refresh-token-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
QR_TOKEN_SECRET="replace-with-qr-token-secret"
QR_TOKEN_TTL="24h"

# Redis / queues
REDIS_URL="redis://localhost:6379"

# Email provider
RESEND_API_KEY="re_..."
MAIL_FROM="e-Pati <noreply@example.com>"

# Firebase push notifications
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Cloudflare R2, S3-compatible storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
